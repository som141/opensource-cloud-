COMPOSE_PROJECT_NAME=image-preprocess-prod

# PostgreSQL
POSTGRES_DB=image_preprocess
POSTGRES_USER=image_preprocess
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_LONG_RANDOM_DB_PASSWORD
POSTGRES_PORT=5432

# RabbitMQ
RABBITMQ_DEFAULT_USER=image_preprocess
RABBITMQ_DEFAULT_PASS=CHANGE_ME_GENERATE_LONG_RANDOM_RABBITMQ_PASSWORD
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# MinIO/S3-compatible object storage
MINIO_ROOT_USER=image_preprocess
MINIO_ROOT_PASSWORD=CHANGE_ME_GENERATE_LONG_RANDOM_MINIO_PASSWORD
MINIO_BUCKET=image-preprocess-prod
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_PUBLIC_ENDPOINT=https://YOUR_DOMAIN
MINIO_REGION=us-east-1
MINIO_API_CORS_ALLOW_ORIGIN=https://YOUR_DOMAIN

# NGINX and backend ports
NGINX_HTTP_PORT=80
BACKEND_API_PORT=8080

# MVP schema policy.
# Use update for first MVP deployment. Switch to validate after database migrations are introduced.
JPA_DDL_AUTO=update

# Google OAuth2.
# Google Console JavaScript origin: https://YOUR_DOMAIN
# Google Console redirect URI: https://YOUR_DOMAIN/login/oauth2/code/google
GOOGLE_CLIENT_ID=CHANGE_ME_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=CHANGE_ME_GOOGLE_CLIENT_SECRET
OAUTH2_SUCCESS_REDIRECT_URI=https://YOUR_DOMAIN/oauth2/success
CORS_ALLOWED_ORIGINS=https://YOUR_DOMAIN

# JWT and refresh cookie.
# JWT_SECRET must be at least 32 bytes and should be generated by a password manager or openssl.
JWT_SECRET=CHANGE_ME_GENERATE_AT_LEAST_32_BYTES_RANDOM_SECRET
ACCESS_TOKEN_EXPIRE_SECONDS=1800
REFRESH_TOKEN_EXPIRE_SECONDS=1209600
REFRESH_TOKEN_COOKIE_NAME=refresh_token
REFRESH_TOKEN_COOKIE_SECURE=true
REFRESH_TOKEN_COOKIE_SAME_SITE=Lax

# Worker internal API.
WORKER_ID=prod-worker-1
WORKER_LISTENER_ENABLED=true
WORKER_INTERNAL_TOKEN=CHANGE_ME_GENERATE_LONG_RANDOM_WORKER_TOKEN
